  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Emergency Plumber Liverpool",
    "description": "24/7 emergency plumber across Liverpool L1 to L40. Gas Safe registered engineers. 30 minute response. Burst pipes, boiler breakdowns, blocked drains, gas leaks. From £80/hour. No call-out fee. Our own employed engineers, no sub-contractors.",
    "provider": {
      "@type": "Plumber",
      "name": "Ideal Plumbing Solutions",
      "telephone": "+4407399676656"
    },
    "areaServed": { "@type": "Place", "name": "Liverpool, L1-L40" },
    "hoursAvailable": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    },
    "offers": [
      { "@type": "Offer", "name": "Weekday Emergency Plumber Liverpool", "price": "80", "priceCurrency": "GBP", "description": "Monday to Friday 8am to 5pm" },
      { "@type": "Offer", "name": "Weekend Emergency Plumber Liverpool", "price": "120", "priceCurrency": "GBP", "description": "Saturday and Sunday 8am to 1pm" },
      { "@type": "Offer", "name": "Out of Hours Emergency Plumber Liverpool", "price": "150", "priceCurrency": "GBP", "description": "Nights and bank holidays, 24/7" }
    ]
  }
  </script>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does an emergency plumber cost in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Weekdays 8am to 5pm: £80 per hour. Weekends 8am to 1pm: £120 per hour. Nights and holidays: £150 per hour. No call-out fee. Minimum 1 hour charge. Parts at cost. Most jobs cost £120 to £350 in total. Written quote before work begins." }
      },
      {
        "@type": "Question",
        "name": "Are you Gas Safe registered?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. All our engineers are Gas Safe registered. You can verify our registration at gassaferegister.co.uk. It is illegal to work on gas appliances without this qualification." }
      },
      {
        "@type": "Question",
        "name": "Do you use sub-contractors?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Every engineer we send is our own directly employed staff. We never use sub-contractors or agency workers. You get the same trained, vetted, insured professional every time." }
      },
      {
        "@type": "Question",
        "name": "How quickly can you reach me in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "We guarantee a 30 minute response across Liverpool L1 to L40. Our average arrival time is 28 minutes. City centre and inner Liverpool typically under 20 minutes. Outlying areas like Formby and Kirkby around 35 minutes." }
      },
      {
        "@type": "Question",
        "name": "What postcodes do you cover in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "We cover all Liverpool postcodes from L1 to L40, including the city centre, Anfield, Aigburth, Wavertree, West Derby, Woolton, Bootle, Crosby, Maghull, Kirkby, Huyton, Formby and Southport." }
      },
      {
        "@type": "Question",
        "name": "Do you cover commercial properties in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We cover commercial emergencies 24/7 across Liverpool including shops, restaurants, offices, hotels and warehouses. Same fixed rates as residential. No commercial premium." }
      },
      {
        "@type": "Question",
        "name": "Do you really answer calls at 3am?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. A real person answers 24 hours a day, 7 days a week. No voicemail, no automated system, no call centre. We answer within 3 rings. Christmas Day, Bank Holidays, 3am Sunday mornings." }
      },
      {
        "@type": "Question",
        "name": "Do you provide certificates for insurance claims?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We provide itemised invoices, photos of damage and repair, gas safety certificates where applicable, and written reports. We are experienced in working with insurance company requirements." }
      },
      {
        "@type": "Question",
        "name": "Do you guarantee your plumbing work?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. All our work carries a full 12-month workmanship guarantee. If anything we fix fails within 12 months due to our work we come back and sort it at no charge across Liverpool." }
      },
      {
        "@type": "Question",
        "name": "What should I do if my pipes are frozen in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Turn off the water at the stopcock immediately. Do not try to thaw frozen pipes with a naked flame. Call us immediately on 07399 676656. A frozen pipe costs far less to fix than a burst one. We attend frozen pipe emergencies 24/7 across all Liverpool postcodes." }
      },
      {
        "@type": "Question",
        "name": "Can you help with water damage insurance claims in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We provide full documentation for insurance claims including itemised invoices, photos of damage and repair, a written report explaining the cause, and gas safety certificates where applicable. We can correspond directly with your insurer if required." }
      },
      {
        "@type": "Question",
        "name": "How much does a burst pipe cost to fix in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most burst pipe repairs in Liverpool cost between £120 and £350 depending on the location of the pipe and severity of the break. We provide a written quote before starting any work." }
      }
    ]
  }
  </script>

  <style>
    .gas-safe-verify {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: #fff7ed;
      border: 1px solid #fed7aa;
      border-radius: var(--radius-sm);
      padding: 0.3rem 0.75rem;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--orange-dark);
      text-decoration: none;
      margin-top: 0.5rem;
      transition: opacity 0.15s;
    }
    .gas-safe-verify:hover { opacity: 0.85; }
    .trust-badges {
      display: flex;
      justify-content: center;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
    }
    .trust-badge {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 0.45rem 1rem;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--navy);
    }
    .price-range-bar {
      background: var(--white);
      border: 1px solid var(--border);
      border-left: 4px solid var(--orange);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      margin-top: 1.5rem;
      text-align: center;
    }
    .price-range-bar strong { color: var(--navy); font-size: 1rem; display: block; margin-bottom: 0.35rem; }
    .price-range-bar p { font-size: 0.9rem; color: var(--muted); margin: 0; }
    .commercial-section { background: var(--navy); padding: 2.5rem 0; }
    .commercial-inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 2rem; }
    .commercial-text h2 { color: var(--white); text-align: center; font-size: clamp(1.6rem, 3vw, 2.2rem); margin-bottom: 0.75rem; }
    .commercial-text p { color: rgba(255,255,255,0.8); font-size: 0.97rem; line-height: 1.75; margin-bottom: 0.75rem; text-align: center; }
    .commercial-types { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; justify-content: center; }
    .commercial-type { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: var(--radius-sm); padding: 0.3rem 0.75rem; font-size: 0.82rem; font-weight: 700; color: var(--white); }
    .commercial-cta { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15); border-radius: var(--radius); padding: 2rem; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.75rem; }
    .commercial-cta strong { color: var(--orange); font-size: 1.05rem; font-weight: 800; }
    .commercial-cta p { color: rgba(255,255,255,0.8); font-size: 0.9rem; margin: 0; }
    .cover-plan-bar { background: #fff7ed; border: 1px solid #fed7aa; border-radius: var(--radius); padding: 1.5rem 2rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap; }
    .cover-plan-bar div { display: flex; flex-direction: column; gap: 0.25rem; }
    .cover-plan-bar strong { color: var(--navy); font-size: 1rem; }
    .cover-plan-bar p { color: var(--muted); font-size: 0.88rem; margin: 0; }
    .no-subcontractors-bar { background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: var(--radius); padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-top: 1.5rem; text-align: center; flex-wrap: wrap; }
    .no-subcontractors-bar strong { color: #15803d; font-size: 0.95rem; }
    .no-subcontractors-bar span { color: #166534; font-size: 0.88rem; }
    @media (max-width: 768px) {
      .commercial-inner { grid-template-columns: 1fr; }
      .commercial-text h2 { text-align: center; }
      .cover-plan-bar { flex-direction: column; text-align: center; }
    }
  </style>

