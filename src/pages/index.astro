>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Ideal Plumbing Solutions",
    "image": "https://www.idealplumbingsolutions.co.uk/ideal-plumbing-logo.png",
    "url": "https://www.idealplumbingsolutions.co.uk",
    "telephone": "+4407399676656",
    "email": "idealplumbingsolutions@gmail.com",
    "priceRange": "££",
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "250",
