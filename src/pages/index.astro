      {
        "@type": "Question",
        "name": "How much does an emergency plumber cost in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Weekdays 8am to 5pm: £80 per hour. Weekends 8am to 1pm: £120 per hour. Nights and holidays: £150 per hour. No call-out fee. Minimum 1 hour charge. Parts charged separately at cost. Written quote provided before work begins." }
      },
      {
        "@type": "Question",
        "name": "Are you Gas Safe registered?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. All our engineers are Gas Safe registered for safe boiler and gas work. It is illegal to work on gas appliances without this qualification. You can verify this at gassaferegister.co.uk." }
      },
      {
        "@type": "Question",
        "name": "How quickly can you reach me in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "We guarantee a 30 minute response across Liverpool. Our average arrival time is 28 minutes. We dispatch immediately when you call and text you the engineer name and ETA." }
