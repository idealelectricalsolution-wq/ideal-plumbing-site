---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Emergency Plumber Liverpool | 30 Min Response | 24 Hour | Gas Safe | From £80"
  description="Emergency plumber Liverpool available 24/7. 30 minute response across L1 to L40. Gas Safe registered. Our own engineers, no sub-contractors. Burst pipes, boiler breakdowns, no hot water, blocked drains, gas leaks. From £80/hour minimum. Call 07399 676656."
  canonical="https://www.idealplumbingsolutions.co.uk"
>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "Plumber"],
    "name": "Ideal Plumbing Solutions",
    "image": "https://www.idealplumbingsolutions.co.uk/ideal-plumbing-logo.png",
    "url": "https://www.idealplumbingsolutions.co.uk",
    "telephone": "+4407399676656",
    "email": "idealplumbingsolutions@gmail.com",
    "priceRange": "££",
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    },
    "areaServed": [
      { "@type": "Place", "name": "Liverpool" }, { "@type": "Place", "name": "Bootle" },
      { "@type": "Place", "name": "Crosby" }, { "@type": "Place", "name": "Maghull" },
      { "@type": "Place", "name": "Kirkby" }, { "@type": "Place", "name": "Huyton" },
      { "@type": "Place", "name": "Wavertree" }, { "@type": "Place", "name": "Aigburth" },
      { "@type": "Place", "name": "Woolton" }, { "@type": "Place", "name": "West Derby" },
      { "@type": "Place", "name": "Formby" }, { "@type": "Place", "name": "Southport" },
      { "@type": "Place", "name": "Wirral" }, { "@type": "Place", "name": "Birkenhead" },
      { "@type": "Place", "name": "Wallasey" }, { "@type": "Place", "name": "Heswall" },
      { "@type": "Place", "name": "St Helens" }, { "@type": "Place", "name": "Warrington" },
      { "@type": "Place", "name": "Stockton Heath" }
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "250",
      "bestRating": "5"
    },
    "review": [
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5" },
        "author": { "@type": "Person", "name": "Sarah M" },
        "reviewBody": "Pipe burst under the sink at 11pm flooding the kitchen. Called and they arrived within 25 minutes. Fixed it quickly, cleaned up and the price was exactly what they quoted. Cannot fault them."
      },
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5" },
        "author": { "@type": "Person", "name": "John K" },
        "reviewBody": "Boiler packed in the middle of winter. Had an engineer here in 20 minutes, diagnosed the problem and had us back up and running within the hour. Fair pricing and absolutely professional."
      }
    ]
  }
  </script>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Emergency Plumber Liverpool",
    "description": "24/7 emergency plumber and 24 hour plumber across Liverpool L1 to L40. Gas Safe registered engineers. 30 minute response. Fixed hourly rates from £80 with 1 hour minimum. Burst pipes, water coming through ceiling, no hot water, boiler breakdown, blocked drains, gas leaks, frozen pipes. Our own employed engineers, no sub-contractors.",
    "provider": { "@type": "Plumber", "name": "Ideal Plumbing Solutions", "telephone": "+4407399676656" },
    "areaServed": { "@type": "Place", "name": "Liverpool, L1-L40" },
    "hoursAvailable": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    },
    "offers": [
      { "@type": "Offer", "name": "Weekday Emergency Plumber Liverpool", "price": "80", "priceCurrency": "GBP", "description": "Monday to Friday 9am to 5pm. 1 hour minimum charge." },
      { "@type": "Offer", "name": "Weekend Emergency Plumber Liverpool", "price": "120", "priceCurrency": "GBP", "description": "Saturday and Sunday 9am to 1pm. 1 hour minimum charge." },
      { "@type": "Offer", "name": "Out of Hours Emergency Plumber Liverpool", "price": "150", "priceCurrency": "GBP", "description": "Nights and bank holidays, 24/7" }
    ]
  }
  </script>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does an emergency plumber cost in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "Weekdays 9am to 5pm: £80 per hour with a 1 hour minimum. Weekends 9am to 1pm: £120 per hour with a 1 hour minimum. Out of hours, nights and holidays: £150 per hour with a 1 hour minimum. Parts charged at cost. Most emergency jobs take 30 to 90 minutes and cost between £80 and £350 in total. Written quote provided before any work begins." } },
      { "@type": "Question", "name": "Are you Gas Safe registered?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. All our engineers are Gas Safe registered. You can verify our registration at gassaferegister.co.uk. It is illegal to work on gas appliances without this qualification." } },
      { "@type": "Question", "name": "Do you use sub-contractors?", "acceptedAnswer": { "@type": "Answer", "text": "No. Every engineer we send is our own directly employed staff. We never use sub-contractors or agency workers. You get the same trained, vetted, insured professional every time." } },
      { "@type": "Question", "name": "How quickly can you reach me in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "We guarantee a 30 minute response across Liverpool L1 to L40. Our average arrival time is 28 minutes. City centre and inner Liverpool typically under 20 minutes. Outlying areas like Formby and Kirkby around 35 minutes." } },
      { "@type": "Question", "name": "What postcodes do you cover in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "We cover all Liverpool postcodes from L1 to L40, including the city centre, Anfield, Aigburth, Wavertree, West Derby, Woolton, Bootle, Crosby, Maghull, Kirkby, Huyton, Formby and Southport." } },
      { "@type": "Question", "name": "Do you cover commercial properties in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We cover commercial emergencies 24/7 across Liverpool including shops, restaurants, offices, hotels and warehouses. Same fixed rates as residential. No commercial premium." } },
      { "@type": "Question", "name": "Do you really answer calls at 3am?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. A real person answers 24 hours a day, 7 days a week. No voicemail, no automated system, no call centre. We answer within 3 rings. Christmas Day, Bank Holidays, 3am Sunday mornings." } },
      { "@type": "Question", "name": "Do you provide certificates for insurance claims?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We provide itemised invoices, photos of damage and repair, gas safety certificates where applicable, and written reports. We are experienced in working with insurance company requirements." } },
      { "@type": "Question", "name": "Do you guarantee your plumbing work?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. All our work carries a full 12-month workmanship guarantee. If anything we fix fails within 12 months due to our work we come back and sort it at no charge across Liverpool." } },
      { "@type": "Question", "name": "What should I do if my pipes are frozen in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "Turn off the water at the stopcock immediately. Do not try to thaw frozen pipes with a naked flame. Call us immediately on 07399 676656. A frozen pipe costs far less to fix than a burst one. We attend frozen pipe emergencies 24/7 across all Liverpool postcodes." } },
      { "@type": "Question", "name": "Can you help with water damage insurance claims in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We provide full documentation for insurance claims including itemised invoices, photos of damage and repair, a written report explaining the cause, and gas safety certificates where applicable. We can correspond directly with your insurer if required." } },
      { "@type": "Question", "name": "How much does a burst pipe cost to fix in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "Most burst pipe repairs in Liverpool cost between £120 and £350 depending on the location of the pipe and severity of the break. We provide a written quote before starting any work." } },
      { "@type": "Question", "name": "Is there a minimum charge for an emergency plumber in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We charge a minimum of 1 hour on all call-outs. Weekdays 9am to 5pm that is £80. Weekends 9am to 1pm that is £120. Out of hours that is £150. After the first hour we charge in 30 minute increments. Parts are charged at cost. Written quote before work begins." } },
      { "@type": "Question", "name": "What should I do if I have no hot water in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "First check your boiler pressure gauge. It should read between 1 and 1.5 bar. Below 0.5 bar you can repressurise using the filling loop. Check for error codes on the boiler display. If neither resolves the problem, call us on 07399 676656. We attend no hot water emergencies 24/7 across Liverpool." } },
      { "@type": "Question", "name": "What should I do if my toilet is blocked in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "Stop flushing immediately. Continued flushing will overflow sewage onto the floor. Turn off the water supply to the toilet at the isolation valve behind it. Call us on 07399 676656. Do not use chemical drain cleaners as these are rarely effective on full blockages." } }
    ]
  }
  </script>

  <!-- HERO -->
  <section class="page-hero">
    <div class="container" style="text-align:center;">
      <div class="page-hero-badge" style="margin:0 auto 1rem;">
        <span class="live-dot"></span>
        Available 24/7 Across Liverpool
      </div>
      <h1>Emergency Plumber Liverpool</h1>
      <p class="page-hero-sub">Burst pipes. Boiler breakdowns. Blocked drains. Gas leaks. We will be there in 30 minutes. Gas Safe registered. Our own Gas Safe engineers. Fixed rates from £80.</p>

      <div style="background:var(--navy);border-radius:var(--radius);padding:1rem 1.5rem;max-width:320px;margin:1.25rem auto;display:flex;flex-direction:column;align-items:center;gap:0.2rem;">
        <span style="font-family:'Barlow Condensed',sans-serif;font-size:3rem;font-weight:900;color:var(--orange);line-height:1;">30<small style="font-size:1.4rem;color:#ffffff;">min</small></span>
        <span style="font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:900;color:#ffffff;line-height:1.2;">Guaranteed Response</span>
        <p style="color:rgba(255,255,255,0.85);font-size:0.85rem;margin:0.3rem 0 0;">From <strong style="color:var(--orange);">£80/hour</strong> · 1 hour minimum · Fixed rates</p>
      </div>

      <div style="display:flex;flex-direction:column;align-items:center;gap:0.6rem;max-width:320px;margin:0 auto 1.5rem;">
        <a href="tel:07399676656" class="btn btn-orange btn-lg btn-full" style="box-shadow:0 4px 14px rgba(249,115,22,0.4);font-size:1.3rem;color:#ffffff;">CALL 07399 676656</a>
        <a href="/get-started" class="btn btn-lg btn-full" style="background:var(--navy);color:#ffffff;border:2px solid var(--navy);">BOOK A SLOT ONLINE</a>
      </div>

      <div class="trust-row">
        <div class="trust-item"><strong>1,200+</strong><span>Emergencies Fixed</span></div>
        <div class="trust-item"><strong>28min</strong><span>Avg Response Time</span></div>
        <div class="trust-item"><strong>24/7</strong><span>We Always Answer</span></div>
      </div>

      <div style="display:flex;justify-content:center;gap:0.75rem;flex-wrap:wrap;margin-top:1.5rem;">
        <span style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.45rem 1rem;font-size:0.82rem;font-weight:700;color:var(--navy);">✓ Gas Safe Registered</span>
        <span style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.45rem 1rem;font-size:0.82rem;font-weight:700;color:var(--navy);">✓ No Sub-Contractors</span>
        <span style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.45rem 1rem;font-size:0.82rem;font-weight:700;color:var(--navy);">✓ 12-Month Guarantee</span>
        <span style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.45rem 1rem;font-size:0.82rem;font-weight:700;color:var(--navy);">✓ £2M Public Liability</span>
        <span style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.45rem 1rem;font-size:0.82rem;font-weight:700;color:var(--navy);">✓ 30 Years Experience</span>
      </div>
    </div>
  </section>

  <div class="pf">
  <!-- WHAT IS AN EMERGENCY -->
  <section class="pf-section" style="background:#f8fafc;">
    <div class="container">
      <h2>What Is a Plumbing Emergency?</h2>
      <p class="pf-sub">Not sure if your situation qualifies? Here is exactly how to tell.</p>
      <div class="emerg-levels" style="margin-top:2rem;">
        <div class="emerg-level emerg-level--danger">
          <div class="level-header">
            <span style="font-size:1.5rem;">🔴</span>
            <div><strong>Call Immediately. Do Not Wait.</strong><span>Stop what you are doing and call now</span></div>
          </div>
          <ul>
            <li>Gas leak. Smell of gas or hissing sound</li>
            <li>Burst pipe. Water pouring out</li>
            <li>Flooding. Water rapidly accumulating</li>
            <li>Sewage overflow from toilet or drain</li>
            <li>Boiler leaking gas or carbon monoxide alarm</li>
            <li>No water to entire property</li>
          </ul>
          <a href="tel:07399676656" class="btn btn-red btn-full" style="margin-top:1rem;color:#ffffff;">Call 07399 676656 Now</a>
        </div>
        <div class="emerg-level emerg-level--urgent">
          <div class="level-header">
            <span style="font-size:1.5rem;">🟡</span>
            <div><strong>Call Today. Do Not Leave Overnight.</strong><span>Urgent but not immediate danger</span></div>
          </div>
          <ul>
            <li>Major leak. Constant drip or puddle forming</li>
            <li>Blocked toilet. Backing up or overflowing</li>
            <li>No hot water. Boiler not working</li>
            <li>Frozen pipes. Risk of bursting</li>
            <li>Water tank overflow</li>
            <li>Radiator leak</li>
          </ul>
          <a href="tel:07399676656" class="btn btn-navy btn-full" style="margin-top:1rem;">Call for Advice</a>
        </div>
        <div class="emerg-level emerg-level--routine">
          <div class="level-header">
            <span style="font-size:1.5rem;">🟢</span>
            <div><strong>Can Wait. Book an Appointment.</strong><span>No immediate danger</span></div>
          </div>
          <ul>
            <li>Dripping tap</li>
            <li>Slow drain</li>
            <li>Boiler service due</li>
            <li>Radiator not heating well</li>
            <li>Shower pressure low</li>
            <li>General plumbing work</li>
          </ul>
          <a href="/get-started" class="btn btn-navy btn-full" style="margin-top:1rem;opacity:0.8;">Book Appointment</a>
        </div>
      </div>
      <p style="text-align:center;margin-top:1.5rem;font-size:0.95rem;color:var(--muted);">Not sure? Call us and we will tell you honestly whether it is an emergency or can wait. <a href="tel:07399676656" style="color:var(--orange);font-weight:700;">07399 676656</a></p>
    </div>
  </section>


  <!-- PRICING -->
  <section class="pf-section" style="background:#f8fafc;">
    <div class="container">
      <h2>Emergency Plumber Liverpool. Fixed Hourly Rates.</h2>
      <p class="pf-sub">Fixed rates with a 1 hour minimum on every call-out. No hidden charges. Parts at cost. The price we quote is the price you pay.</p>

      <div class="pf-pricing-grid">
        <div class="pf-price-card">
          <div class="pf-price-tier">WEEKDAY EMERGENCY</div>
          <div class="pf-price-name">Monday to Friday</div>
          <div class="pf-price-sub">9am to 5pm</div>
          <div class="pf-price-amount">£80<small>/hr</small></div>
