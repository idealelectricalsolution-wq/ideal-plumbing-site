---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Emergency Plumber Liverpool L1-L40 | 30 Min Response | Gas Safe | No Sub-Contractors"
  description="Emergency plumber Liverpool available 24/7 across L1 to L40. 30 minute response. Gas Safe registered. Our own engineers, no sub-contractors. Burst pipes, boiler breakdowns, gas leaks. From £80/hour. No call-out fee. Call 07399 676656."
  canonical="https://www.idealplumbingsolutions.co.uk"
>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "Plumber"],
    "name": "Ideal Plumbing Solutions",
    "image": "https://www.idealplumbingsolutions.co.uk/ideal-plumbing-logo.png",
    "url": "https://www.idealplumbingsolutions.co.uk",
    "telephone": "+4407399676656",
    "email": "idealplumbingsolutions@gmail.com",
    "priceRange": "££",
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
      "opens": "00:00",
      "closes": "23:59"
    },
    "areaServed": [
      { "@type": "Place", "name": "Liverpool" },
      { "@type": "Place", "name": "Bootle" },
      { "@type": "Place", "name": "Crosby" },
      { "@type": "Place", "name": "Maghull" },
      { "@type": "Place", "name": "Kirkby" },
      { "@type": "Place", "name": "Huyton" },
      { "@type": "Place", "name": "Wavertree" },
      { "@type": "Place", "name": "Aigburth" },
      { "@type": "Place", "name": "Woolton" },
      { "@type": "Place", "name": "West Derby" },
      { "@type": "Place", "name": "Formby" },
      { "@type": "Place", "name": "Southport" },
      { "@type": "Place", "name": "Wirral" },
      { "@type": "Place", "name": "Birkenhead" },
      { "@type": "Place", "name": "Wallasey" },
      { "@type": "Place", "name": "Heswall" },
      { "@type": "Place", "name": "St Helens" },
      { "@type": "Place", "name": "Warrington" },
      { "@type": "Place", "name": "Stockton Heath" }
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "250",
      "bestRating": "5"
    },
    "review": [
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5" },
        "author": { "@type": "Person", "name": "Sarah M" },
        "reviewBody": "Pipe burst under the sink at 11pm flooding the kitchen. Called and they arrived within 25 minutes. Fixed it quickly, cleaned up and the price was exactly what they quoted. Cannot fault them."
      },
      {
        "@type": "Review",
        "reviewRating": { "@type": "Rating", "ratingValue": "5" },
        "author": { "@type": "Person", "name": "John K" },
        "reviewBody": "Boiler packed in the middle of winter. Had an engineer here in 20 minutes, diagnosed the problem and had us back up and running within the hour. Fair pricing and absolutely professional."
      }
    ]
  }
