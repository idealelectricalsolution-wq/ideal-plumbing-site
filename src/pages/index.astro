  <!-- SAFETY ADVICE -->
  <section class="section-pad">
    <div class="container">
      <h2 class="section-title">What To Do Before We Arrive</h2>
      <p class="section-sub">Follow these steps while our engineer makes their way to you.</p>
      <div class="safety-grid">
        <div class="safety-card safety-card--gas">
          <h3>If You Smell Gas</h3>
          <ul>
            <li>Do not turn any switches on or off</li>
            <li>Open all doors and windows immediately</li>
            <li>Turn off gas at the meter if safe to do so</li>
            <li>Get everyone out of the property</li>
            <li>Call Gas Emergency on 0800 111 999</li>
            <li>Then call us once made safe</li>
          </ul>
        </div>
        <div class="safety-card safety-card--pipe">
          <h3>If a Pipe Bursts</h3>
          <ul>
            <li>Turn off water at the stopcock immediately</li>
            <li>Turn off water heating and immersion heater</li>
            <li>Turn on all taps to drain remaining water</li>
            <li>Mop up water to prevent damage</li>
            <li>Move valuables away from the leak</li>
            <li>Call us immediately on 07399 676656</li>
          </ul>
        </div>
        <div class="safety-card safety-card--never">
          <h3>Never Do This</h3>
          <ul style="list-style:none;">
            <li style="padding-left:1rem;position:relative;"><span style="position:absolute;left:0;color:var(--red);font-weight:700;">✕</span>Use a naked flame to find a gas leak</li>
            <li style="padding-left:1rem;position:relative;"><span style="position:absolute;left:0;color:var(--red);font-weight:700;">✕</span>Attempt to repair gas pipes yourself</li>
            <li style="padding-left:1rem;position:relative;"><span style="position:absolute;left:0;color:var(--red);font-weight:700;">✕</span>Ignore a repeatedly tripping boiler</li>
            <li style="padding-left:1rem;position:relative;"><span style="position:absolute;left:0;color:var(--red);font-weight:700;">✕</span>Keep flushing a blocked toilet</li>
            <li style="padding-left:1rem;position:relative;"><span style="position:absolute;left:0;color:var(--red);font-weight:700;">✕</span>Use electrical switches near water</li>
          </ul>
        </div>
