      {
        "@type": "Question",
        "name": "Do you charge a call-out fee?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Unlike many Liverpool plumbers we do not charge a separate call-out fee. You pay our hourly rate from when we start diagnosing the problem. Minimum charge is 1 hour." }
      }
    ]
  }
