      { "@type": "Question", "name": "Are you G3 qualified for unvented cylinder work in Formby?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. All our engineers hold G3 qualifications for unvented cylinder work. This is a mandatory requirement for working on mains pressure hot water systems, which are common in Formby's larger properties. Many installers do not hold this qualification and cannot legally service or replace unvented cylinders." } },
