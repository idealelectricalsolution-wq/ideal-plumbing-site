  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does a boiler service cost in Liverpool?", "acceptedAnswer": { "@type": "Answer", "text": "A standard annual boiler service in Liverpool costs £120 fixed price including the service certificate issued the same day. A combined boiler service and CP12 gas safety certificate costs £175 in a single visit. No call-out fee, no hidden extras. Call Ideal Plumbing Solutions on 07399 676656 to book." } },
      { "@type": "Question", "name": "Is a boiler service a legal requirement?", "acceptedAnswer": { "@type": "Answer", "text": "For homeowners, an annual boiler service is not a legal requirement but is strongly recommended by the HSE, Gas Safe Register and all major manufacturers as a condition of the warranty. For landlords, an annual gas safety inspection is a legal requirement under the Gas Safety Regulations 1998. Landlords must hold a valid CP12 certificate and provide a copy to tenants within 28 days of issue." } },
      { "@type": "Question", "name": "How often should I service my boiler?", "acceptedAnswer": { "@type": "Answer", "text": "Every year, without exception. All major boiler manufacturers including Worcester Bosch and Vaillant require annual servicing by a Gas Safe registered engineer to keep the warranty valid. Missing a single year can void a 10-year warranty entirely. A serviced boiler also runs up to 15% more efficiently than an unserviced one, saving money on gas bills every month." } },
      { "@type": "Question", "name": "Can I service my own boiler?", "acceptedAnswer": { "@type": "Answer", "text": "No. A gas boiler service must be carried out by a Gas Safe registered engineer. This is a legal requirement under the Gas Safety Regulations. Attempting to service a gas boiler yourself is illegal and dangerous. Always verify your engineer's Gas Safe registration at gassaferegister.co.uk before any gas work." } },
      { "@type": "Question", "name": "What happens if a fault is found during the service?", "acceptedAnswer": { "@type": "Answer", "text": "If we find a fault or developing issue during the service, we explain exactly what we found and provide a written repair quote before any additional work is carried out. We never start repair work without your approval. You are never charged for work you have not agreed to." } },
