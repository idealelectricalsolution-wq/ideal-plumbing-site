---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Boiler Service Liverpool | £75 Fixed Price | Gas Safe | Same Day | Ideal Plumbing Solutions"
  description="Annual boiler service in Liverpool from £75. Gas Safe registered engineers. Service certificate provided same day. All major brands. Liverpool, Wirral, Warrington and St Helens covered. Call 07399 676656."
  canonical="https://www.idealplumbingsolutions.co.uk/boiler-service-liverpool"
>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "Plumber"],
    "name": "Ideal Plumbing Solutions",
    "url": "https://www.idealplumbingsolutions.co.uk/boiler-service-liverpool",
    "telephone": "+4407399676656",
    "priceRange": "££",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "250",
      "bestRating": "5"
    }
  }
  </script>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Boiler Service Liverpool",
    "alternateName": ["Annual Boiler Service Liverpool", "Boiler Servicing Liverpool", "Gas Boiler Service Liverpool"],
    "description": "Annual gas boiler service in Liverpool from £75 fixed price. Gas Safe registered engineers. Service certificate provided same day. All major brands including Worcester Bosch, Vaillant, Ideal and Baxi.",
    "provider": { "@type": "Plumber", "name": "Ideal Plumbing Solutions", "telephone": "+4407399676656" },
    "areaServed": [
      { "@type": "Place", "name": "Liverpool" },
      { "@type": "Place", "name": "Wirral" },
      { "@type": "Place", "name": "Warrington" },
      { "@type": "Place", "name": "St Helens" }
    ],
    "offers": [
      { "@type": "Offer", "name": "Annual Boiler Service Liverpool", "price": "75", "priceCurrency": "GBP", "description": "Full annual gas boiler service including all checks, cleaning and service certificate." },
      { "@type": "Offer", "name": "Boiler Service and Gas Safety Certificate Liverpool", "price": "120", "priceCurrency": "GBP", "description": "Combined annual boiler service and CP12 gas safety certificate. One visit, two documents." }
    ]
  }
  </script>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a boiler service cost in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Our annual boiler service in Liverpool costs £75 fixed price. This includes all checks, cleaning, efficiency tests and a service certificate. A combined boiler service and gas safety certificate (CP12) is £120. No hidden fees. Liverpool market rates range from £55 to £110 for a standard service." }
      },
      {
        "@type": "Question",
        "name": "How long does a boiler service take in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "A standard annual boiler service takes between 45 minutes and 1 hour. If additional cleaning or minor repairs are required it may take slightly longer. We confirm the time and any additional costs before carrying out any extra work." }
      },
      {
        "@type": "Question",
        "name": "How often should I service my boiler?",
        "acceptedAnswer": { "@type": "Answer", "text": "Boilers should be serviced annually. All major manufacturers including Worcester Bosch, Vaillant and Ideal require annual servicing as a condition of their warranty. Landlords should service boilers annually alongside their CP12 gas safety certificate." }
      },
      {
        "@type": "Question",
        "name": "What happens during a boiler service?",
        "acceptedAnswer": { "@type": "Answer", "text": "Our Gas Safe engineer carries out a full inspection including: visual check of the boiler and flue, checking gas pressure and flow, cleaning the burner and heat exchanger, testing the ignition, checking safety devices, inspecting seals and gaskets and verifying correct operation. A service certificate is issued on completion." }
      },
      {
        "@type": "Question",
        "name": "Will an unserviced boiler void my warranty?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. All major boiler manufacturers including Worcester Bosch, Vaillant, Ideal and Baxi require annual servicing by a Gas Safe registered engineer as a condition of their warranty. Missing a service can void a 10-year warranty, leaving you responsible for the full cost of any repairs or replacement." }
      },
      {
        "@type": "Question",
        "name": "Do you service all boiler brands in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We service all major boiler brands across Liverpool including Worcester Bosch, Vaillant, Ideal, Baxi, Potterton, Glow-worm, Intergas and Alpha. Our Gas Safe engineers carry the most common parts and tools for all of these brands on every visit." }
      },
      {
        "@type": "Question",
        "name": "Do you provide a boiler service certificate for landlords?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We provide a full service certificate on completion of every boiler service. Landlords can combine the boiler service with a CP12 gas safety certificate for £120 in a single visit, providing all documentation needed for tenants and letting agents." }
      }
    ]
  }
  </script>

  <style>
    .bs-page { }
    .bs-page h2 { text-align: center; color: var(--navy); }
    .bs-page .section-sub { text-align: center; }
    .bs-page p { font-size: 0.97rem; }
    .bs-page li { font-size: 0.97rem; }
    .bs-page .faq-body p { font-size: 0.95rem; }
    .bs-page .review-card > p { font-size: 0.94rem; line-height: 1.75; }

    /* CHECK LIST */
    .check-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }
    .check-item {
      background: var(--white);
      border: 1px solid var(--border);
      border-left: 3px solid var(--orange);
      border-radius: var(--radius-sm);
      padding: 1rem 1.25rem;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .check-num {
      background: var(--orange);
      color: var(--white);
      font-family: 'Barlow Condensed', sans-serif;
      font-weight: 900;
      font-size: 1rem;
      min-width: 1.75rem;
      height: 1.75rem;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .check-text strong { display: block; color: var(--navy); font-size: 0.95rem; margin-bottom: 0.2rem; }
    .check-text p { color: var(--muted); font-size: 0.88rem; margin: 0; }

    /* BRANDS */
    .brand-pill-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }
    .brand-pill {
      background: var(--bg);
      border: 1px solid var(--border);
      border-top: 3px solid var(--orange);
      border-radius: var(--radius);
      padding: 1.25rem;
      text-align: center;
    }
    .brand-pill strong { display: block; color: var(--navy); font-size: 1.1rem; font-family: 'Barlow Condensed', sans-serif; font-weight: 900; margin-bottom: 0.25rem; }
    .brand-pill p { color: var(--muted); font-size: 0.87rem; margin: 0; }

    /* SIGNS */
    .signs-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }
    .sign-item {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 1rem 1.25rem;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .sign-icon { color: var(--orange); font-weight: 900; font-size: 1.2rem; flex-shrink: 0; min-width: 1.25rem; }
    .sign-item strong { display: block; color: var(--navy); font-size: 0.95rem; margin-bottom: 0.15rem; }
    .sign-item p { color: var(--muted); font-size: 0.85rem; margin: 0; }

    /* WARRANTY BOX */
    .warranty-box {
      background: var(--navy);
      border-radius: var(--radius);
      padding: 2rem;
      text-align: center;
      margin-top: 1.5rem;
    }
    .warranty-box h3 { color: var(--orange); font-size: 1.4rem; margin-bottom: 0.5rem; }
    .warranty-box p { color: rgba(255,255,255,0.85); font-size: 0.95rem; margin-bottom: 1rem; }
    .warranty-brands {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
      margin-bottom: 1.25rem;
    }
    .warranty-brand {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: var(--radius-sm);
      padding: 0.3rem 0.75rem;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--white);
    }

    /* COMBINE BOX */
    .combine-box {
      background: var(--white);
      border: 1px solid var(--border);
      border-top: 4px solid var(--orange);
      border-radius: var(--radius);
      padding: 2rem;
      text-align: center;
      margin-top: 1.5rem;
    }
    .combine-box h3 { color: var(--navy); font-size: 1.3rem; margin-bottom: 0.5rem; }
    .combine-price {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 3rem;
      font-weight: 900;
      color: var(--orange);
      line-height: 1;
      margin: 0.5rem 0 0.25rem;
    }
    .combine-price small { font-size: 1rem; color: var(--muted); }
    .saving-pill {
      display: inline-block;
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      color: #15803d;
      font-size: 0.82rem;
      font-weight: 800;
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      margin-bottom: 0.75rem;
    }
    .combine-box p { color: var(--muted); font-size: 0.92rem; margin-bottom: 1.25rem; }
    .combine-items {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.5rem;
      margin-bottom: 1.25rem;
      text-align: left;
    }
    .combine-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem;
      color: var(--text);
      padding: 0.5rem 0.75rem;
      background: var(--bg);
      border-radius: var(--radius-sm);
    }
    .combine-item span { color: var(--orange); font-weight: 700; }

    /* LANDLORD BAR */
    .landlord-bar {
      background: var(--navy);
      border-radius: var(--radius);
      padding: 1.5rem 2rem;
      margin-top: 1.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
    }
    .landlord-bar strong { color: var(--orange); font-size: 1rem; display: block; }
    .landlord-bar p { color: rgba(255,255,255,0.85); font-size: 0.9rem; margin: 0; }

    /* SERVICES GRID */
    .bs-services-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .bs-service-link {
      background: var(--navy);
      border-top: 3px solid var(--orange);
      border-radius: var(--radius);
      padding: 1.25rem;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.35rem;
      transition: transform 0.18s;
    }
    .bs-service-link:hover { transform: translateY(-3px); }
    .bs-service-link strong { color: var(--orange); font-size: 1rem; font-weight: 800; }
    .bs-service-link span { color: rgba(255,255,255,0.8); font-size: 0.88rem; }

    .bs-page a { color: var(--navy); font-weight: 700; text-decoration: none; border-bottom: 1px solid rgba(26,58,92,0.25); transition: border-color 0.2s; }
    .bs-page a:hover { border-color: var(--navy); }
    .bs-page .btn { border-bottom: none; }
  </style>

  <div class="bs-page">

  <!-- HERO -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-badge">
        <span class="badge-dot"></span>
        Gas Safe Registered · Certificate Same Day · All Major Brands
      </div>
      <h1>Boiler Service Liverpool</h1>
      <p class="page-hero-sub" style="font-size:1rem;">Annual boiler service from <strong>£75 fixed price</strong>. Gas Safe registered engineers. Certificate provided same day. Protects your warranty. All major brands across Liverpool, Wirral, Warrington and St Helens.</p>

      <div style="display:flex;flex-direction:row;justify-content:center;gap:1rem;flex-wrap:wrap;margin-bottom:1rem;">
        <div style="background:var(--navy);border-radius:var(--radius);padding:0.75rem 1.5rem;text-align:center;min-width:140px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;font-weight:900;color:var(--orange);line-height:1;">£75</div>
          <div style="font-size:0.8rem;color:rgba(255,255,255,0.85);font-weight:700;">Annual Service</div>
        </div>
        <div style="background:var(--orange);border-radius:var(--radius);padding:0.75rem 1.5rem;text-align:center;min-width:140px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;font-weight:900;color:var(--white);line-height:1;">£120</div>
          <div style="font-size:0.8rem;color:rgba(255,255,255,0.9);font-weight:700;">Service and CP12</div>
        </div>
        <div style="background:var(--navy);border-radius:var(--radius);padding:0.75rem 1.5rem;text-align:center;min-width:140px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;font-weight:900;color:var(--orange);line-height:1;">1hr</div>
          <div style="font-size:0.8rem;color:rgba(255,255,255,0.85);font-weight:700;">Average Duration</div>
        </div>
      </div>

      <p style="color:rgba(255,255,255,0.75);font-size:0.82rem;margin-bottom:1.5rem;">Fixed price. No hidden fees. Certificate included. Free annual reminder service.</p>

      <div class="hero-actions">
        <a href="tel:07399676656" class="btn btn-orange btn-lg" style="box-shadow:0 4px 14px rgba(249,115,22,0.4);">CALL 07399 676656</a>
        <a href="/contact-3" class="btn btn-lg" style="background:var(--white);color:var(--navy);border:2px solid var(--navy);">BOOK ONLINE</a>
      </div>

      <div class="trust-row">
        <div class="trust-item">
          <strong>Gas Safe</strong>
          <span>Registered<br>Engineers</span>
        </div>
        <div class="trust-item">
          <strong>No Sub-</strong>
          <span>Contractors<br>Ever</span>
        </div>
        <div class="trust-item">
          <strong>5.0 ★</strong>
          <span>250 Google<br>Reviews</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="section-pad" style="background:var(--bg);">
    <div class="container">
      <h2>Boiler Service Prices Liverpool</h2>
      <p class="section-sub">Fixed prices. No hidden charges. No call-out fee. The price we quote is the price you pay.</p>

      <div style="display:grid;grid-template-columns:1fr;gap:1.25rem;margin-top:1.5rem;">
        <div class="price-card">
          <div class="price-tier">STANDARD SERVICE</div>
          <div class="price-name">Annual Boiler Service</div>
          <div class="price-sub">All major brands. All Liverpool postcodes.</div>
          <div class="price-amount">£<span>75</span></div>
          <ul>
            <li><span style="color:#16a34a;font-weight:700;">✓</span> Full 10-point inspection</li>
            <li><span style="color:#16a34a;font-weight:700;">✓</span> Burner and heat exchanger clean</li>
            <li><span style="color:#16a34a;font-weight:700;">✓</span> Flue and combustion test</li>
            <li><span style="color:#16a34a;font-weight:700;">✓</span> Service certificate same day</li>
            <li><span style="color:#16a34a;font-weight:700;">✓</span> Free annual renewal reminder</li>
          </ul>
          <a href="tel:07399676656" class="btn btn-navy btn-full">Book Now</a>
        </div>

        <div class="price-card price-card--featured">
          <div class="price-card-badge">BEST VALUE FOR LANDLORDS</div>
          <div class="price-tier">COMBINED</div>
          <div class="price-name">Service and Gas Safety Certificate</div>
          <div class="price-sub">One visit. Two documents.</div>
          <div class="price-amount">£<span>120</span></div>
          <ul>
            <li><span style="color:#16a34a;font-weight:700;">✓</span> Full annual boiler service</li>
            <li><span style="color:#16a34a;font-weight:700;">✓</span> CP12 gas safety certificate</li>
            <li><span style="color:#16a34a;font-weight:700;">✓</span> Both documents emailed same day</li>
            <li><span style="color:#16a34a;font-weight:700;">✓</span> Landlord and letting agent compliant</li>
            <li><span style="color:#16a34a;font-weight:700;">✓</span> Portfolio discounts available</li>
          </ul>
          <a href="tel:07399676656" class="btn btn-orange btn-full">Book Combined Visit</a>
        </div>
      </div>

      <div style="background:var(--white);border:1px solid var(--border);border-left:4px solid var(--orange);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-top:1.5rem;text-align:center;">
        <strong style="color:var(--navy);display:block;margin-bottom:0.35rem;">How does our price compare?</strong>
        <p style="color:var(--muted);font-size:0.9rem;margin:0;">Liverpool boiler service prices range from £55 to £110 according to <a href="https://www.hamuch.com/cost/boiler-service/liverpool" target="_blank" rel="noopener">HaMuch price data</a>. At £75 we are competitively priced while using only our own Gas Safe registered engineers, not sub-contractors. The <a href="https://www.mybuilder.com/central-heating/price-guides/boiler-service-cost" target="_blank" rel="noopener">MyBuilder national average is £80</a> for a standard gas boiler service.</p>
      </div>
    </div>
  </section>

  <!-- WHY ANNUAL SERVICING MATTERS -->
  <section class="section-pad" style="background:var(--white);">
    <div class="container">
      <h2>Why Every Liverpool Boiler Needs an Annual Service</h2>
      <p class="section-sub">An annual boiler service is not just good practice. For most Liverpool homeowners it is essential for safety, savings and warranty protection.</p>

      <div style="display:grid;grid-template-columns:1fr;gap:1rem;margin-top:1.5rem;">
        <div style="background:var(--bg);border:1px solid var(--border);border-top:3px solid var(--orange);border-radius:var(--radius);padding:1.5rem;text-align:center;">
          <h3 style="color:var(--navy);margin-bottom:0.5rem;">Safety</h3>
          <p style="color:var(--muted);">A poorly maintained boiler is the leading cause of carbon monoxide leaks in the home. An annual service catches failing components, blocked flues and incomplete combustion before they become dangerous. The <a href="https://www.hse.gov.uk/gas/domestic/" target="_blank" rel="noopener">HSE recommends annual gas appliance servicing</a> for all domestic properties. See <a href="https://www.nhs.uk/conditions/carbon-monoxide-poisoning/" target="_blank" rel="noopener">NHS carbon monoxide guidance</a> for the health risks of a faulty boiler.</p>
        </div>
        <div style="background:var(--bg);border:1px solid var(--border);border-top:3px solid var(--orange);border-radius:var(--radius);padding:1.5rem;text-align:center;">
          <h3 style="color:var(--navy);margin-bottom:0.5rem;">Warranty Protection</h3>
          <p style="color:var(--muted);">All major boiler manufacturers require annual servicing by a Gas Safe registered engineer as a condition of their warranty. Missing a single service can void a 10-year Worcester Bosch or Vaillant warranty, leaving you personally responsible for the full cost of any repair or replacement. We provide a service certificate as proof for your warranty records.</p>
        </div>
        <div style="background:var(--bg);border:1px solid var(--border);border-top:3px solid var(--orange);border-radius:var(--radius);padding:1.5rem;text-align:center;">
          <h3 style="color:var(--navy);margin-bottom:0.5rem;">Efficiency and Lower Bills</h3>
          <p style="color:var(--muted);">A serviced boiler runs up to 10% more efficiently than an unserviced one. Over a year that translates to a meaningful reduction in gas bills. The <a href="https://energysavingtrust.org.uk/advice/boilers/" target="_blank" rel="noopener">Energy Saving Trust</a> recommends annual servicing as one of the most cost-effective ways to reduce home energy use. A £75 service typically pays for itself within months through improved efficiency.</p>
        </div>
        <div style="background:var(--bg);border:1px solid var(--border);border-top:3px solid var(--orange);border-radius:var(--radius);padding:1.5rem;text-align:center;">
          <h3 style="color:var(--navy);margin-bottom:0.5rem;">Fewer Breakdowns</h3>
          <p style="color:var(--muted);">80% of boiler breakdowns in winter are caused by faults that could have been detected and fixed during a routine service. An annual service catches worn parts, low pressure, scale buildup and ignition issues before they cause a complete breakdown. The average emergency boiler repair in Liverpool costs £150 to £500. A £75 service is the best insurance available.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE CHECK -->
  <section class="section-pad" style="background:var(--bg);">
    <div class="container">
      <h2>What Our Gas Safe Engineers Check During a Liverpool Boiler Service</h2>
      <p class="section-sub">A thorough 10-point inspection covering every aspect of your boiler's safety and performance. Takes around 45 minutes to 1 hour.</p>

      <div class="check-grid">
        <div class="check-item">
          <div class="check-num">1</div>
          <div class="check-text">
            <strong>Visual inspection of the boiler and casing</strong>
            <p>We check the boiler body, casing and surrounding area for signs of corrosion, leaks, damage or poor installation that could indicate a developing problem.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-num">2</div>
          <div class="check-text">
            <strong>Burner and heat exchanger inspection and clean</strong>
            <p>The burner is removed, inspected and cleaned. A dirty burner reduces efficiency and can cause carbon monoxide production. The heat exchanger is inspected for scaling, corrosion and blockages.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-num">3</div>
          <div class="check-text">
            <strong>Flue flow and combustion analysis</strong>
            <p>We test the flue to confirm harmful gases including carbon monoxide are being safely expelled from the property. A flue analysis confirms the boiler is burning gas correctly and efficiently.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-num">4</div>
          <div class="check-text">
            <strong>Gas pressure and flow rate check</strong>
            <p>Gas pressure at the boiler inlet and burner is checked and adjusted if necessary to confirm the boiler is receiving the correct supply and operating within safe parameters.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-num">5</div>
          <div class="check-text">
            <strong>Ignition and safety device testing</strong>
            <p>The ignition system and all safety devices including the flame failure device, overheat thermostat and pressure relief valve are tested to confirm correct operation.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-num">6</div>
          <div class="check-text">
            <strong>Seals, gaskets and condensate check</strong>
            <p>All internal seals and gaskets are inspected for wear or deterioration. The condensate trap and pipework are checked to confirm they are clear and draining correctly.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-num">7</div>
          <div class="check-text">
            <strong>System pressure and expansion vessel check</strong>
            <p>Boiler pressure is checked and topped up if necessary. The expansion vessel is checked for correct pressure and operation to prevent pressure build-up in the system.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-num">8</div>
          <div class="check-text">
            <strong>Controls and thermostat operation</strong>
            <p>The programmer, thermostat and any smart controls are tested to confirm they are operating correctly and communicating properly with the boiler.</p>
          </div>
        </div>
        <div class="check-item">
          <div class="check-num">9</div>
          <div class="check-text">
            <strong>Magnetic filter and inhibitor check</strong>
            <p>If a magnetic system filter is fitted we clean it and check inhibitor levels in the heating circuit. Correct inhibitor levels prevent sludge build-up that can damage the boiler and reduce efficiency.</p>
          </div>
        </div>
