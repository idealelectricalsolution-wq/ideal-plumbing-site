    .sign-item p { color: var(--muted); font-size: 0.85rem; margin: 0; }

    .flush-box {
      background: var(--navy);
      border-radius: var(--radius);
      padding: 2rem;
      text-align: center;
      margin-top: 1.5rem;
    }
