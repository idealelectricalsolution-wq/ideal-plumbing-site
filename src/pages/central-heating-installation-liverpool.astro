      grid-template-columns: 1fr;
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .ch-service-link {
      background: var(--navy);
      border-top: 3px solid var(--orange);
      border-radius: var(--radius);
      padding: 1.25rem;
      text-decoration: none;
