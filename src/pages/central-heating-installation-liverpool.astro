    }
    .ch-service-link:hover { transform: translateY(-3px); }
    .ch-service-link strong { color: var(--orange); font-size: 1rem; font-weight: 800; }
    .ch-service-link span { color: rgba(255,255,255,0.8); font-size: 0.88rem; }

