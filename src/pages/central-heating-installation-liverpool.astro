  <!-- HOW IT WORKS -->
  <section class="section-pad eicr-process-section">
    <div class="container">
      <h2 style="text-align:center;">How Our Liverpool Central Heating Installation Works</h2>
      <p class="section-sub">From free survey to a fully working heating system, here is exactly what to expect.</p>
      <div class="process-steps">
        <div class="process-step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>Free Site Survey</h3>
            <p>We visit your Liverpool property, assess your heating requirements and carry out a full heat loss calculation for every room. Written fixed-price quote provided with no obligation.</p>
