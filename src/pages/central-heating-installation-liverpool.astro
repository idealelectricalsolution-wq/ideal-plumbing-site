    .service-cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
      margin-top: 1.5rem;
    }
    .service-card-item {
      background: var(--white);
      border: 1px solid var(--border);
      border-top: 3px solid var(--orange);
      border-radius: var(--radius);
      padding: 1.75rem;
      text-align: center;
    }
