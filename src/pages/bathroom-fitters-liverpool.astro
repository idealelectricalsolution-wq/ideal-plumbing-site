      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section-pad" style="background:var(--white);">
    <div class="container">
      <h2>Bathroom Fitting Services Across Liverpool</h2>
      <p class="section-sub">From a simple shower replacement to a complete bathroom transformation. Everything covered by our own team.</p>

      <div class="service-type-grid">
        <div class="service-type-card">
          <div class="service-type-icon">FULL</div>
