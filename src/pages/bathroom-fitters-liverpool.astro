  <!-- THE BIG ADVANTAGE -->
  <section class="section-pad" style="background:var(--bg);">
    <div class="container">
      <h2>One Contractor for Everything. The Ideal Difference.</h2>
      <p class="section-sub">Most Liverpool bathroom renovations go wrong because homeowners are juggling multiple tradesmen. We are different.</p>

      <div class="advantage-box">
        <h3>No Juggling Multiple Tradesmen</h3>
        <div class="advantage-list">
          <div class="advantage-item"><span>✓</span> One team handles the plumbing, tiling, fitting and all finishing work</div>
          <div class="advantage-item"><span>✓</span> One fixed-price quote covering everything from strip-out to final seal</div>
