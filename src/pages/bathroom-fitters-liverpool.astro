      <div class="trust-row">
        <div class="trust-item">
          <strong>One Team</strong>
          <span>Plumbing, Tiling<br>and Fitting</span>
        </div>
        <div class="trust-item">
          <strong>No Sub-</strong>
          <span>Contractors<br>Ever</span>
        </div>
