  <!-- WHAT IS INCLUDED -->
  <section class="section-pad" style="background:var(--white);">
    <div class="container">
      <h2>What Is Included in Your Liverpool Bathroom Installation</h2>
      <p class="section-sub">Our fully managed service covers every stage from initial strip-out to final finishing. No extra invoices on completion.</p>

      <div class="included-grid">
        <div class="included-row">
          <span class="included-tick">✓</span>
          <div><strong>Free site survey and written fixed-price quote</strong><span>We visit your bathroom, discuss your requirements and provide a written quote before any work begins. No obligation to proceed.</span></div>
        </div>
        <div class="included-row">
          <span class="included-tick">✓</span>
