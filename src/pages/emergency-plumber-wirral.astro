---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Emergency Plumber Wirral | 30 Min Response | 24 Hour | Gas Safe | From £80"
  description="Emergency plumber Wirral available 24/7. 30 minute response across all CH postcodes from Birkenhead to Heswall and West Kirby. Gas Safe registered. Our own engineers, no sub-contractors. Burst pipes, boiler breakdowns, blocked drains. From £80/hour. Call 0151 558 0334."
