        </div>

        <div class="pf-price-card">
          <div class="pf-price-tier">SYSTEM UPGRADE</div>
          <div class="pf-price-name">Heating System Upgrade</div>
          <div class="pf-price-sub">Upgrading or extending an existing system</div>
          <div class="pf-price-amount">£1,500</div>
          <ul class="pf-price-list">
            <li>New boiler where required</li>
