  <!-- PRICING -->
  <section class="pf-section" style="background:#f8fafc;">
    <div class="container">
      <h2 style="text-align:center;">Central Heating Installation Prices Wirral</h2>
      <p class="pf-sub">Free site survey required to confirm your exact price. All prices include installation, controls, Gas Safe certificate and 12-month workmanship guarantee.</p>

      <div class="pf-pricing-grid">
        <div class="pf-price-card pf-price-card-featured">
          <div class="pf-price-badge">MOST COMMON</div>
          <div class="pf-price-tier">FULL SYSTEM</div>
          <div class="pf-price-name">New Central Heating Installation</div>
