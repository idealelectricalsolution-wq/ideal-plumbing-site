---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Boiler Installation Liverpool | New Boiler From £1,800 | Gas Safe | Ideal Plumbing Solutions"
  description="New boiler installation in Liverpool from £1,800 fully fitted. Worcester Bosch, Vaillant and Ideal specialists. Gas Safe registered. Free survey. 10-year warranty available. Liverpool, Wirral, Warrington and St Helens. Call 07399 676656."
  canonical="https://www.idealplumbingsolutions.co.uk/boiler-installation-liverpool"
>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "Plumber"],
    "name": "Ideal Plumbing Solutions",
    "url": "https://www.idealplumbingsolutions.co.uk/boiler-installation-liverpool",
    "telephone": "+4407399676656",
    "priceRange": "££",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "250",
      "bestRating": "5"
    }
  }
  </script>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Boiler Installation Liverpool",
    "alternateName": ["New Boiler Liverpool", "Boiler Replacement Liverpool", "Combi Boiler Installation Liverpool"],
    "description": "New boiler installation across Liverpool from £1,800 fully fitted. Worcester Bosch, Vaillant and Ideal specialists. Gas Safe registered engineers. Free survey. 10-year warranty available.",
    "provider": { "@type": "Plumber", "name": "Ideal Plumbing Solutions", "telephone": "+4407399676656" },
    "areaServed": [
      { "@type": "Place", "name": "Liverpool" },
      { "@type": "Place", "name": "Wirral" },
      { "@type": "Place", "name": "Warrington" },
      { "@type": "Place", "name": "St Helens" }
    ],
    "offers": [
      { "@type": "Offer", "name": "Combi Boiler Installation Liverpool", "price": "1800", "priceCurrency": "GBP", "description": "Like-for-like combi boiler replacement fully fitted including new boiler, controls and certificate." },
      { "@type": "Offer", "name": "System Boiler Installation Liverpool", "price": "2200", "priceCurrency": "GBP", "description": "System boiler installation fully fitted." },
      { "@type": "Offer", "name": "Regular Boiler Installation Liverpool", "price": "2500", "priceCurrency": "GBP", "description": "Regular/conventional boiler installation fully fitted." }
    ]
  }
  </script>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does a new boiler cost in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "A like-for-like combi boiler replacement in Liverpool starts from £1,800 fully fitted. System boilers start from £2,200 and regular boilers from £2,500. The Checkatrade average for Liverpool is £1,677 to £2,733. Prices depend on the boiler brand, output size and any additional work required." }
      },
      {
        "@type": "Question",
        "name": "How long does a boiler installation take in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "A straightforward like-for-like combi boiler replacement typically takes 4 to 6 hours and is completed in a single day. More complex installations involving system conversions, new pipework or moving the boiler location take 1 to 3 days." }
      },
      {
        "@type": "Question",
        "name": "Which boiler brands do you install in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "We install Worcester Bosch, Vaillant, Ideal and Baxi boilers across Liverpool. All are A-rated energy-efficient condensing boilers. Worcester Bosch and Vaillant are our primary recommendations for reliability, efficiency and warranty length." }
      },
      {
        "@type": "Question",
        "name": "Is there a government grant for a new boiler in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Eligible Liverpool homeowners may qualify for the Boiler Upgrade Scheme (BUS) for heat pumps, or the ECO4 scheme for those on qualifying benefits or low incomes. We assess eligibility at the free survey. Visit the GOV.UK Boiler Upgrade Scheme page for full details." }
      },
      {
        "@type": "Question",
        "name": "What warranty do I get with a new boiler in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Worcester Bosch and Vaillant boilers come with up to 10-year manufacturer warranties when installed by an accredited installer. Ideal and Baxi offer between 5 and 10 years. All our installations also carry a 12-month workmanship guarantee." }
      },
      {
        "@type": "Question",
        "name": "Do you offer free boiler installation surveys in Liverpool?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We offer free no-obligation site surveys across Liverpool and Merseyside. Our Gas Safe engineer assesses your property, recommends the right boiler type and output, and provides a written fixed-price quote before any work begins." }
      },
      {
        "@type": "Question",
        "name": "Will a new boiler increase my property value?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Studies show a new boiler can increase property value by around 4% and improve the Energy Performance Certificate (EPC) rating, which can add a further 14% to value. For a Liverpool property worth £200,000, that is a potential uplift of £8,000 to £36,000 from a single installation." }
      }
    ]
  }
  </script>

  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Get a New Boiler Installed in Liverpool",
    "estimatedCost": { "@type": "MonetaryAmount", "currency": "GBP", "value": "1800" },
    "totalTime": "P1D",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Free Survey", "text": "We visit your Liverpool property, assess your heating requirements and recommend the right boiler type and brand. Written fixed-price quote provided with no obligation." },
      { "@type": "HowToStep", "position": 2, "name": "Choose Your Boiler", "text": "We advise on the best boiler for your property size, hot water demand and budget. Worcester Bosch, Vaillant, Ideal and Baxi all available." },
      { "@type": "HowToStep", "position": 3, "name": "Installation Day", "text": "Our Gas Safe engineers carry out the full installation. Most like-for-like replacements are completed in a single day. We protect your home, remove the old boiler and clean up fully before leaving." },
      { "@type": "HowToStep", "position": 4, "name": "Certificate and Handover", "text": "We issue the Gas Safe installation certificate, register the boiler warranty with the manufacturer and walk you through the new controls before we leave." }
    ]
  }
  </script>

  <style>
    .bi-page h2 { text-align: center; color: var(--navy); }
    .bi-page .section-sub { text-align: center; }
    .bi-page p { font-size: 0.97rem; }
    .bi-page li { font-size: 0.97rem; }
    .bi-page .faq-body p { font-size: 0.95rem; }
    .bi-page .review-card > p { font-size: 0.94rem; line-height: 1.75; }
    .brand-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .brand-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-top: 3px solid var(--orange);
      border-radius: var(--radius);
      padding: 1.5rem;
      text-align: center;
    }
    .brand-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 1.75rem;
      font-weight: 900;
      color: var(--navy);
      margin-bottom: 0.25rem;
    }
    .brand-tag { font-size: 0.78rem; font-weight: 700; color: var(--orange); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.5rem; }
    .brand-card p { font-size: 0.88rem; color: var(--muted); margin-bottom: 0.75rem; }
    .brand-warranty { display: inline-block; background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; font-size: 0.78rem; font-weight: 700; padding: 0.2rem 0.75rem; border-radius: 999px; }
    .boiler-type-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
      margin-top: 1.5rem;
    }
    .boiler-type-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.75rem;
      text-align: center;
    }
    .boiler-type-card--recommended { border-top: 3px solid var(--orange); background: var(--white); }
    .boiler-type-label { font-size: 0.72rem; font-weight: 800; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.25rem; }
    .boiler-type-name { font-family: 'Barlow Condensed', sans-serif; font-size: 1.75rem; font-weight: 900; color: var(--navy); margin-bottom: 0.25rem; }
    .boiler-type-price { font-family: 'Barlow Condensed', sans-serif; font-size: 2.5rem; font-weight: 900; color: var(--orange); line-height: 1; margin: 0.5rem 0; }
    .boiler-type-price small { font-size: 1rem; color: var(--muted); }
    .boiler-type-card p { font-size: 0.88rem; color: var(--muted); margin-bottom: 0.75rem; }
    .boiler-type-card ul { list-style: none; text-align: left; display: flex; flex-direction: column; gap: 0.35rem; max-width: 300px; margin: 0 auto 1rem; }
    .boiler-type-card ul li { font-size: 0.88rem; color: var(--text); padding-left: 1.1rem; position: relative; }
    .boiler-type-card ul li::before { content: '✓'; position: absolute; left: 0; color: var(--orange); font-weight: 700; }
    .signs-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }
    .sign-item {
      background: var(--white);
      border: 1px solid var(--border);
      border-left: 3px solid var(--orange);
      border-radius: var(--radius-sm);
      padding: 0.9rem 1.25rem;
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .sign-item strong { display: block; color: var(--navy); font-size: 0.95rem; margin-bottom: 0.15rem; }
    .sign-item p { color: var(--muted); font-size: 0.85rem; margin: 0; }
    .included-list {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.75rem;
      margin-top: 1.5rem;
    }
    .included-item {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 1rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-align: left;
    }
    .included-tick { color: var(--orange); font-weight: 900; font-size: 1.1rem; flex-shrink: 0; }
    .included-item strong { color: var(--navy); font-size: 0.95rem; display: block; margin-bottom: 0.1rem; }
    .included-item span { color: var(--muted); font-size: 0.85rem; }
    .value-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-top: 3px solid var(--orange);
      border-radius: var(--radius);
      padding: 1.5rem;
      text-align: center;
      margin-bottom: 1rem;
    }
    .value-stat { font-family: 'Barlow Condensed', sans-serif; font-size: 3rem; font-weight: 900; color: var(--orange); line-height: 1; margin-bottom: 0.25rem; }
    .value-card h3 { color: var(--navy); font-size: 1.1rem; margin-bottom: 0.5rem; }
    .value-card p { color: var(--muted); font-size: 0.88rem; }
    .grant-box {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-left: 4px solid #16a34a;
      border-radius: var(--radius);
      padding: 1.5rem;
      text-align: center;
      margin-top: 1.5rem;
    }
    .grant-box h3 { color: #15803d; font-size: 1.2rem; margin-bottom: 0.5rem; }
    .grant-box p { color: #166534; font-size: 0.92rem; margin-bottom: 0.75rem; }
    .bi-services-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-top: 1.5rem;
    }
    .bi-service-link {
      background: var(--navy);
      border-top: 3px solid var(--orange);
      border-radius: var(--radius);
      padding: 1.25rem;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.35rem;
      transition: transform 0.18s;
    }
    .bi-service-link:hover { transform: translateY(-3px); }
    .bi-service-link strong { color: var(--orange); font-size: 1rem; font-weight: 800; }
    .bi-service-link span { color: rgba(255,255,255,0.8); font-size: 0.88rem; }
    .bi-page a { color: var(--navy); font-weight: 700; text-decoration: none; border-bottom: 1px solid rgba(26,58,92,0.25); transition: border-color 0.2s; }
    .bi-page a:hover { border-color: var(--navy); }
    .bi-page .btn { border-bottom: none; }
  </style>

  <div class="bi-page">

  <!-- HERO -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-badge">
        <span class="badge-dot"></span>
        Gas Safe Registered · Free Survey · 10-Year Warranty Available
      </div>
      <h1>New Boiler Installation Liverpool</h1>
      <p class="page-hero-sub" style="font-size:1rem;">Worcester Bosch, Vaillant and Ideal specialists. Fully fitted from £1,800. Gas Safe registered engineers. Our own staff, no sub-contractors. Free site survey across Liverpool and Merseyside.</p>

      <div style="display:flex;flex-direction:row;justify-content:center;gap:1rem;flex-wrap:wrap;margin-bottom:1rem;">
        <div style="background:var(--navy);border-radius:var(--radius);padding:0.75rem 1.5rem;text-align:center;min-width:140px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;font-weight:900;color:var(--orange);line-height:1;">£1,800</div>
          <div style="font-size:0.8rem;color:rgba(255,255,255,0.85);font-weight:700;">Combi From</div>
        </div>
        <div style="background:var(--navy);border-radius:var(--radius);padding:0.75rem 1.5rem;text-align:center;min-width:140px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;font-weight:900;color:var(--orange);line-height:1;">10yr</div>
          <div style="font-size:0.8rem;color:rgba(255,255,255,0.85);font-weight:700;">Warranty Available</div>
        </div>
        <div style="background:var(--orange);border-radius:var(--radius);padding:0.75rem 1.5rem;text-align:center;min-width:140px;">
          <div style="font-family:'Barlow Condensed',sans-serif;font-size:2.5rem;font-weight:900;color:var(--white);line-height:1;">FREE</div>
          <div style="font-size:0.8rem;color:rgba(255,255,255,0.9);font-weight:700;">Site Survey</div>
        </div>
      </div>

      <p style="color:rgba(255,255,255,0.75);font-size:0.82rem;margin-bottom:1.5rem;">Fully fitted prices. Certificate included. No hidden fees. Finance available.</p>

      <div class="hero-actions">
        <a href="tel:07399676656" class="btn btn-orange btn-lg" style="box-shadow:0 4px 14px rgba(249,115,22,0.4);">CALL 07399 676656</a>
        <a href="/contact-3" class="btn btn-lg" style="background:var(--white);color:var(--navy);border:2px solid var(--navy);">BOOK FREE SURVEY</a>
      </div>

      <div class="trust-row">
        <div class="trust-item">
          <strong>Gas Safe</strong>
          <span>Registered<br>Engineers</span>
        </div>
        <div class="trust-item">
          <strong>No Sub-</strong>
          <span>Contractors<br>Ever</span>
        </div>
        <div class="trust-item">
          <strong>5.0 ★</strong>
          <span>250 Google<br>Reviews</span>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING BY TYPE -->
  <section class="section-pad" style="background:var(--bg);">
    <div class="container">
      <h2>New Boiler Installation Prices Liverpool</h2>
      <p class="section-sub">Fully fitted prices including the new boiler, installation, controls and Gas Safe certificate. Free survey required to confirm exact price for your property.</p>

      <div class="boiler-type-grid">
        <div class="boiler-type-card boiler-type-card--recommended">
          <div class="price-card-badge" style="position:static;transform:none;display:inline-block;margin-bottom:0.5rem;">MOST POPULAR</div>
          <div class="boiler-type-label">COMBI BOILER</div>
          <div class="boiler-type-name">Like-for-Like Replacement</div>
          <div class="boiler-type-price">£1,800<small>+</small></div>
          <p>The most common boiler installation in Liverpool. Ideal for flats and smaller terraced homes with one bathroom. No hot water cylinder needed.</p>
          <ul>
            <li>Worcester Bosch, Vaillant or Ideal</li>
            <li>Completed in a single day</li>
            <li>Up to 10-year manufacturer warranty</li>
            <li>New smart thermostat included</li>
            <li>Gas Safe certificate issued</li>
          </ul>
          <a href="tel:07399676656" class="btn btn-orange btn-full">Get Fixed Quote</a>
        </div>

        <div class="boiler-type-card">
          <div class="boiler-type-label">SYSTEM BOILER</div>
          <div class="boiler-type-name">With Hot Water Cylinder</div>
          <div class="boiler-type-price">£2,200<small>+</small></div>
          <p>Suitable for larger Liverpool homes with multiple bathrooms or higher hot water demand. Works with a separate hot water storage cylinder.</p>
          <ul>
            <li>Best for 3 bed and larger properties</li>
            <li>Supports multiple bathrooms</li>
            <li>Up to 10-year manufacturer warranty</li>
            <li>Cylinder installation included in quote</li>
            <li>Gas Safe certificate issued</li>
          </ul>
          <a href="tel:07399676656" class="btn btn-navy btn-full">Get Free Quote</a>
        </div>

        <div class="boiler-type-card">
          <div class="boiler-type-label">REGULAR BOILER</div>
          <div class="boiler-type-name">Conventional Heat-Only</div>
          <div class="boiler-type-price">£2,500<small>+</small></div>
          <p>Common in Liverpool's older Victorian properties with gravity-fed systems, separate hot water cylinders and cold water tanks in the loft.</p>
          <ul>
            <li>Specialist knowledge of older Liverpool stock</li>
            <li>Compatible with existing radiator systems</li>
            <li>Up to 10-year manufacturer warranty</li>
            <li>Full system assessment included</li>
            <li>Gas Safe certificate issued</li>
          </ul>
          <a href="tel:07399676656" class="btn btn-navy btn-full">Get Free Quote</a>
        </div>
      </div>

      <div style="background:var(--white);border:1px solid var(--border);border-left:4px solid var(--orange);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-top:1.5rem;text-align:center;">
        <strong style="color:var(--navy);display:block;margin-bottom:0.35rem;">Why we quote after a site survey</strong>
        <p style="color:var(--muted);font-size:0.9rem;margin:0;">The true cost of a boiler installation depends on your property layout, existing pipework, boiler location, flue route and chosen brand. The <a href="https://www.checkatrade.com/blog/cost-guides/new-boiler-cost/" target="_blank" rel="noopener">Checkatrade average for Liverpool is £1,677 to £2,733</a>. We visit your property, assess everything and provide a written fixed-price quote with no obligation to proceed. No surprises on invoice day.</p>
      </div>
    </div>
  </section>

  <!-- BRANDS WE INSTALL -->
  <section class="section-pad" style="background:var(--white);">
    <div class="container">
      <h2>Boiler Brands We Install in Liverpool</h2>
      <p class="section-sub">We fit the four most trusted boiler brands in the UK. All are A-rated energy-efficient condensing boilers compliant with <a href="https://www.gov.uk/guidance/boiler-plus" target="_blank" rel="noopener" style="color:var(--navy);">Boiler Plus regulations</a>.</p>

      <div class="brand-grid">
        <div class="brand-card">
          <div class="brand-name">Worcester Bosch</div>
          <div class="brand-tag">Our Primary Recommendation</div>
          <p>The UK's most trusted boiler brand. Outstanding build quality, excellent efficiency ratings and an industry-leading warranty. The Greenstar range is our top recommendation for most Liverpool homes. Worcester Bosch is consistently rated number one by Which? for reliability.</p>
          <span class="brand-warranty">Up to 10-year manufacturer warranty</span>
        </div>

        <div class="brand-card">
          <div class="brand-name">Vaillant</div>
          <div class="brand-tag">Premium Eco-Friendly Performance</div>
          <p>Vaillant boilers are renowned for exceptional build quality and leading eco-credentials. The ecoTEC range is particularly well suited to Liverpool's larger Victorian and Edwardian properties with complex heating systems. Excellent long-term reliability record.</p>
          <span class="brand-warranty">Up to 10-year manufacturer warranty</span>
        </div>

        <div class="brand-card">
          <div class="brand-name">Ideal</div>
          <div class="brand-tag">Made in the UK. Great Value.</div>
          <p>Ideal boilers are manufactured in Hull and represent outstanding value for money without compromising on quality. The Logic range is a reliable choice for budget-conscious Liverpool homeowners and landlords. Strong spare parts availability across the North West.</p>
          <span class="brand-warranty">Up to 10-year manufacturer warranty</span>
        </div>

        <div class="brand-card">
          <div class="brand-name">Baxi</div>
          <div class="brand-tag">Reliable and Budget-Friendly</div>
          <p>Baxi boilers offer dependable performance at a competitive price point. A good choice for Liverpool rental properties where cost-effectiveness matters. Manufactured in the UK with a strong service network across Merseyside.</p>
          <span class="brand-warranty">Up to 7-year manufacturer warranty</span>
        </div>
      </div>

      <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:1.25rem 1.5rem;margin-top:1.5rem;text-align:center;">
        <p style="color:var(--muted);font-size:0.9rem;margin:0;">All boilers we install are A-rated condensing boilers meeting current <a href="https://www.gov.uk/guidance/boiler-plus" target="_blank" rel="noopener">Boiler Plus regulations</a>. We also fit smart thermostats to comply with Boiler Plus requirements. See the <a href="https://energysavingtrust.org.uk/advice/boilers/" target="_blank" rel="noopener">Energy Saving Trust boiler guide</a> for independent advice on choosing the right boiler for your home.</p>
      </div>
    </div>
  </section>

  <!-- SIGNS YOU NEED A NEW BOILER -->
  <section class="section-pad" style="background:var(--bg);">
    <div class="container">
      <h2>Signs Your Liverpool Boiler Needs Replacing</h2>
      <p class="section-sub">Liverpool's housing stock includes a high proportion of older boilers. If your boiler is over 10 years old or showing any of these signs, a replacement is worth considering.</p>

      <div class="signs-grid">
        <div class="sign-item">
          <span style="color:var(--orange);font-weight:900;font-size:1.2rem;flex-shrink:0;">!</span>
          <div>
            <strong>Boiler is over 10 years old</strong>
            <p>Modern A-rated boilers are up to 30% more efficient than boilers installed before 2010. A new boiler typically saves £200 to £300 per year on energy bills.</p>
          </div>
        </div>
        <div class="sign-item">
          <span style="color:var(--orange);font-weight:900;font-size:1.2rem;flex-shrink:0;">!</span>
          <div>
            <strong>Frequent breakdowns or repairs</strong>
            <p>If you are spending more than £300 per year on repairs, replacing the boiler is almost always more cost-effective in the long run.</p>
          </div>
        </div>
        <div class="sign-item">
          <span style="color:var(--orange);font-weight:900;font-size:1.2rem;flex-shrink:0;">!</span>
          <div>
            <strong>Rising energy bills</strong>
            <p>An inefficient boiler works harder and uses more gas to produce the same heat. A modern condensing boiler can capture up to 94% of the energy from fuel versus 60 to 70% for older models.</p>
          </div>
        </div>
        <div class="sign-item">
          <span style="color:var(--red);font-weight:900;font-size:1.2rem;flex-shrink:0;">!</span>
          <div>
            <strong>Yellow or orange flame instead of blue</strong>
            <p>A yellow flame indicates incomplete combustion and a potential carbon monoxide risk. Call us immediately. See <a href="https://www.nhs.uk/conditions/carbon-monoxide-poisoning/" target="_blank" rel="noopener">NHS carbon monoxide guidance</a>.</p>
          </div>
        </div>
        <div class="sign-item">
          <span style="color:var(--orange);font-weight:900;font-size:1.2rem;flex-shrink:0;">!</span>
          <div>
            <strong>Strange noises or leaking</strong>
