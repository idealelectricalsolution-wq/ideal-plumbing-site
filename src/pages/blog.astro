---
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = [
  { slug: "how-much-does-a-new-boiler-cost-liverpool", category: "BOILERS", borderColor: "#f97316", title: "How Much Does a New Boiler Cost in Liverpool in 2026?", excerpt: "Liverpool boiler installation prices range from £1,800 for a like-for-like combi swap to £7,000 for a full system replacement. Here is exactly what affects the price and what you should pay.", date: "April 2026", readTime: "6 min read" },
  { slug: "signs-your-boiler-needs-replacing-liverpool", category: "BOILERS", borderColor: "#f97316", title: "7 Signs Your Liverpool Boiler Needs Replacing in 2026", excerpt: "Your boiler is trying to tell you something. Here are the seven signs Liverpool homeowners miss that indicate a replacement is more cost-effective than another repair.", date: "March 2026", readTime: "5 min read" },
  { slug: "best-boiler-brands-liverpool-2026", category: "BOILERS", borderColor: "#f97316", title: "Worcester Bosch vs Vaillant: Which Is the Best Boiler for Liverpool Homes?", excerpt: "The two most popular premium boiler brands compared head to head. Efficiency, warranty, reliability and price all assessed by our Gas Safe engineers.", date: "January 2026", readTime: "7 min read" },
  { slug: "carbon-monoxide-safety-liverpool", category: "GAS SAFETY", borderColor: "#1a3a5c", title: "Carbon Monoxide in Liverpool Homes: The Silent Risk Every Homeowner Should Know", excerpt: "Around 40 people die from accidental carbon monoxide poisoning in England every year, most from faulty gas appliances. Here is how to protect your Liverpool home.", date: "December 2025", readTime: "5 min read" },
  { slug: "hmo-gas-safety-liverpool-landlords", category: "LANDLORDS", borderColor: "#7c3aed", title: "HMO Gas Safety in Liverpool: A Complete Compliance Guide for Landlords", excerpt: "HMO landlords in Liverpool face stricter gas safety requirements. This guide covers everything you need for Liverpool City Council HMO licensing.", date: "November 2025", readTime: "7 min read" },
  { slug: "what-is-a-power-flush-liverpool", category: "CENTRAL HEATING", borderColor: "#16a34a", title: "What Is a Power Flush and Does My Liverpool Home Need One?", excerpt: "Cold spots on radiators, a noisy boiler and slow warm-up times are classic signs. A power flush from £350 can restore efficiency and save your Liverpool home £200 a year in energy bills.", date: "February 2026", readTime: "5 min read" },
  { slug: "central-heating-liverpool-victorian-terrace", category: "CENTRAL HEATING", borderColor: "#16a34a", title: "Installing Central Heating in Liverpool's Victorian Terraces: What You Need to Know", excerpt: "Liverpool has one of the highest concentrations of Victorian housing in England. Here is what is different about installing central heating in a period property and what it costs.", date: "January 2026", readTime: "6 min read" },
  { slug: "emergency-plumber-liverpool-what-to-do", category: "EMERGENCY", borderColor: "#dc2626", title: "Burst Pipe in Liverpool? Here Is Exactly What To Do Right Now", excerpt: "The first 10 minutes after a burst pipe are critical. Follow these steps to minimise water damage to your Liverpool property before the plumber arrives.", date: "February 2026", readTime: "4 min read" },
  { slug: "frozen-pipes-liverpool-winter-guide", category: "EMERGENCY", borderColor: "#dc2626", title: "Frozen Pipes in Liverpool: How to Prevent Them and What to Do if They Burst", excerpt: "Liverpool winters cause hundreds of frozen pipe emergencies every year. Most could be prevented. Here is the complete guide for homeowners in Liverpool's older housing stock.", date: "October 2025", readTime: "5 min read" },
  { slug: "bathroom-renovation-liverpool-property-value", category: "BATHROOMS", borderColor: "#0891b2", title: "Does a New Bathroom Add Value to a Liverpool Property? The Numbers.", excerpt: "A well-fitted bathroom can add up to 5% to your Liverpool property value. Here is what the research shows and what you should spend.", date: "December 2025", readTime: "5 min read" },
  { slug: "eco4-scheme-liverpool-free-boiler", category: "GRANTS", borderColor: "#16a34a", title: "ECO4 Scheme Liverpool: Could You Get a Free Boiler in 2026?", excerpt: "The ECO4 scheme provides free boilers and heating upgrades for eligible Liverpool households on benefits or low incomes. Here is how to check if you qualify.", date: "November 2025", readTime: "6 min read" },
];
---

<BaseLayout
  title="Plumbing and Gas Learning Centre Liverpool | Ideal Plumbing Solutions"
  description="Expert plumbing and gas advice for Liverpool homeowners and landlords. Boiler costs, gas safety guides, central heating tips and emergency advice from Gas Safe registered engineers."
  canonical="https://www.idealplumbingsolutions.co.uk/blog"
>

  <style>
    .blog-page h2 { text-align: center; color: var(--navy); }
    .blog-page .section-sub { text-align: center; }
    .category-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-top: 1.5rem; }
    .category-pill { background: var(--white); border: 1px solid var(--border); border-radius: 999px; padding: 0.4rem 1rem; font-size: 0.82rem; font-weight: 700; color: var(--navy); transition: all 0.15s; text-decoration: none; }
    .category-pill:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }
    .posts-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; margin-top: 1.25rem; }
    @media (min-width: 640px) { .posts-grid { grid-template-columns: 1fr 1fr; } }
    .post-card { background: var(--white); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; display: flex; flex-direction: column; transition: transform 0.18s, box-shadow 0.18s; text-decoration: none; color: inherit; }
    .post-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
    .post-card-bar { height: 4px; flex-shrink: 0; }
    .post-card-inner { padding: 1.25rem 1.5rem 1.5rem; display: flex; flex-direction: column; flex: 1; }
    .post-cat-tag { display: inline-block; font-size: 0.68rem; font-weight: 800; padding: 0.2rem 0.6rem; border-radius: 999px; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 0.6rem; align-self: flex-start; color: #fff; }
    .post-card-title { font-size: 1rem; font-weight: 800; color: var(--navy); line-height: 1.35; margin: 0 0 0.5rem; }
    .post-meta { font-size: 0.75rem; color: var(--muted); margin-bottom: 0.75rem; }
    .post-card-excerpt { color: var(--muted); font-size: 0.87rem; line-height: 1.65; flex: 1; margin-bottom: 1rem; }
    .post-read-link { font-size: 0.85rem; font-weight: 700; color: var(--orange); }
    .category-section { margin-top: 2.5rem; }
    .cat-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; padding-bottom: 0.6rem; border-bottom: 2px solid var(--border); }
    .cat-header-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .cat-header h3 { font-size: 1.1rem; font-weight: 800; color: var(--navy); margin: 0; }
    .featured-card { background: var(--white); border: 1px solid var(--border); border-top: 4px solid var(--navy); border-radius: var(--radius); padding: 1.5rem 2rem; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.75rem; }
    .featured-label { font-size: 0.7rem; font-weight: 800; color: var(--orange); text-transform: uppercase; letter-spacing: 0.1em; }
    .featured-card h3 { color: var(--navy); font-size: 1.2rem; margin: 0; line-height: 1.35; }
    .featured-card p { color: var(--muted); font-size: 0.88rem; margin: 0; max-width: 520px; }
    .newsletter-box { background: var(--navy); border-radius: var(--radius); padding: 2rem; text-align: center; margin-top: 2rem; }
    .newsletter-box h3 { color: var(--orange); font-size: 1.2rem; margin-bottom: 0.4rem; }
    .newsletter-box > p { color: rgba(255,255,255,0.8); font-size: 0.88rem; margin-bottom: 1.25rem; }
    .newsletter-form { display: flex; flex-direction: column; gap: 0.75rem; max-width: 380px; margin: 0 auto; }
    .newsletter-form input { padding: 0.75rem 1rem; border: 1px solid rgba(255,255,255,0.2); border-radius: var(--radius-sm); background: rgba(255,255,255,0.1); color: var(--white); font-size: 0.95rem; font-family: inherit; width: 100%; box-sizing: border-box; }
    .newsletter-form input::placeholder { color: rgba(255,255,255,0.4); }
    .newsletter-form input:focus { outline: none; border-color: var(--orange); }
    .newsletter-note { font-size: 0.72rem; color: rgba(255,255,255,0.4); }
    .blog-page a { color: var(--navy); font-weight: 700; text-decoration: none; }
    .blog-page .btn { border-bottom: none; }
    .service-link { background: var(--white); border: 1px solid var(--border); border-left: 3px solid var(--orange); border-radius: var(--radius-sm); padding: 0.85rem 1.25rem; display: flex; justify-content: space-between; align-items: center; text-decoration: none; }
    .service-link:hover { background: #fff7ed; }
    .service-link span { font-weight: 700; color: var(--navy); font-size: 0.88rem; }
    .service-link em { color: var(--orange); font-weight: 900; font-style: normal; }
  </style>

  <div class="blog-page">

  <section class="page-hero">
